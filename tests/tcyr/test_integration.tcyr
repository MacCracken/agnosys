fn test_logging() {
    println("-- logging --");
    assert_eq(log_get_level(), LOG_INFO, "log_def");
    log_set_level(LOG_DEBUG);
    assert_eq(log_get_level(), LOG_DEBUG, "log_dbg");
    log_set_level(LOG_ERROR);
    assert_eq(log_get_level(), LOG_ERROR, "log_err");
    log_set_level(LOG_INFO);
    assert_eq(log_get_level(), LOG_INFO, "log_rst");
    assert(streq(log_level_prefix(LOG_TRACE), "[TRACE] ") == 1, "pfx_t");
    assert(streq(log_level_prefix(LOG_INFO), "[INFO]  ") == 1, "pfx_i");
    assert(streq(log_level_prefix(LOG_ERROR), "[ERROR] ") == 1, "pfx_e");
    return 0;
}

# ================================================================
# security (11 assertions)
# ================================================================

fn test_security() {
    println("-- security --");
    var fres = security_create_basic_seccomp_filter();
    assert(is_ok(fres) == 1, "seccomp");
    var fi = payload(fres);
    assert_eq(security_seccomp_filter_len(fi), 184, "sc_len");
    assert(security_seccomp_filter_ptr(fi) != 0, "sc_ptr");
    assert_eq(security_syscall_name_to_nr("read"), 0, "nr_read");
    assert_eq(security_syscall_name_to_nr("write"), 1, "nr_write");
    assert_eq(security_syscall_name_to_nr("close"), 3, "nr_close");
    assert_eq(security_syscall_name_to_nr("getpid"), 39, "nr_pid");
    assert_eq(security_syscall_name_to_nr("exit"), 60, "nr_exit");
    assert_eq(security_syscall_name_to_nr("xxx"), 0 - 1, "nr_miss");
    assert_eq(security_fs_rule_access(security_fs_rule_read_only("/t")), FS_READ_ONLY, "fs_ro");
    assert_eq(security_fs_rule_access(security_fs_rule_read_write("/t")), FS_READ_WRITE, "fs_rw");
    # H-2 (1.1.14): exercise construct paths so the surface is integration-tested
    # even when the runtime doesn't apply the policies (kavach's job).
    var rule = security_fs_rule_new("/etc", FS_READ_ONLY);
    assert(streq(security_fs_rule_path(rule), "/etc") == 1, "fs_path");
    security_syscall_map_reset();
    assert_eq(security_syscall_name_to_nr("read"), 0, "map_reset_rebuild");
    return 0;
}

# ================================================================
# certpin (13 assertions)
# ================================================================

fn test_certpin() {
    println("-- certpin --");
    var p = "YLh1dUR9y6Kja30RrAn7JKnbQG/uEtLMkBgFF2Fuihg=";
    assert_eq(certpin_validate_pin_format(p), 1, "pin_ok");
    assert_eq(certpin_validate_pin_format("bad"), 0, "pin_bad");
    assert_eq(certpin_validate_pin_format(""), 0, "pin_empty");
    assert_eq(certpin_ct_streq(p, p), 1, "ct_eq");
    assert_eq(certpin_ct_streq(p, "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="), 0, "ct_ne");
    assert_eq(certpin_ct_streq("abc", "abc"), 1, "ct_short");
    assert_eq(certpin_ct_streq("abc", "abd"), 0, "ct_diff");
    var e = certpin_entry_new("example.com", 1700000000);
    assert(streq(certpin_entry_host(e), "example.com") == 1, "ce_host");
    assert_eq(certpin_entry_expires(e), 1700000000, "ce_exp");
    assert_eq(certpin_entry_pin_count(e), 0, "ce_pc0");
    assert_eq(certpin_check_pin_expiry(e, 1600000000), 0, "not_exp");
    assert_eq(certpin_check_pin_expiry(e, 1800000000), 1, "exp");
    var ci = certpin_info_new();
    certpin_info_set_subject(ci, "CN=test");
    assert(streq(certpin_info_subject(ci), "CN=test") == 1, "ci_sub");
    var sb = str_builder_new();
    certpin_info_to_json(ci, sb);
    var json = str_builder_build(sb);
    var sb_exp = str_builder_new();
    str_builder_add_cstr(sb_exp, "{\"subject\":\"CN=test\",\"issuer\":null,\"serial\":null,");
    str_builder_add_cstr(sb_exp, "\"not_before\":0,\"not_after\":0,\"sha256_fp\":null,\"spki_sha256\":null}");
    assert(str_eq(json, str_builder_build(sb_exp)) == 1, "ci_json");
    return 0;
}

# ================================================================
# update (15 assertions)
# ================================================================

fn test_update() {
    println("-- update --");
    assert(is_ok(update_validate_version("2025.3.1")) == 1, "v_good");
    assert(is_err_result(update_validate_version("")) == 1, "v_empty");
    assert(is_err_result(update_validate_version("bad")) == 1, "v_bad");
    assert_eq(update_compare_versions("2025.1.0", "2025.2.0"), VER_LESS, "less");
    assert_eq(update_compare_versions("2025.3.0", "2025.3.0"), VER_EQUAL, "equal");
    assert_eq(update_compare_versions("2025.3.1", "2025.3.0"), VER_GREATER, "greater");
    assert_eq(update_other_slot(SLOT_A), SLOT_B, "sl_a");
    assert_eq(update_other_slot(SLOT_B), SLOT_A, "sl_b");
    assert(streq(update_slot_str(SLOT_A), "A") == 1, "sl_sa");
    assert(streq(update_slot_str(SLOT_B), "B") == 1, "sl_sb");
    assert(streq(update_phase_str(PHASE_DOWNLOADING), "Downloading") == 1, "ph_dl");
    assert(streq(update_phase_str(PHASE_COMPLETE), "Complete") == 1, "ph_ok");
    var us = update_state_new(SLOT_A, "2026.5.1");
    update_state_set_boot_count(us, 7);
    var sb = str_builder_new();
    update_state_to_json(us, sb);
    var json = str_builder_build(sb);
    var sb_exp = str_builder_new();
    str_builder_add_cstr(sb_exp, "{\"slot\":1,\"version\":\"2026.5.1\",\"pending\":0,");
    str_builder_add_cstr(sb_exp, "\"rollback_available\":0,\"boot_count\":7}");
    assert(str_eq(json, str_builder_build(sb_exp)) == 1, "us_json");

    # Regression (1.3.0): update_check on a manifest larger than the
    # 16384-byte read buffer must not overflow. The old read loop let
    # `total` reach 16384, so the trailing `store8(buf+total,0)` wrote
    # one byte past a full buffer. Manifest is >16383 bytes with the
    # version field near the front so it still parses after truncation.
    var mpath = "/tmp/agnos-update-bigmanifest.json";
    var mbuf = alloc(20000);
    var mhdr = "{\"version\":\"9999.1.0\",\"pad\":\"";
    var mp = strlen(mhdr);
    memcpy(mbuf, mhdr, mp);
    memset(mbuf + mp, 65, 18000);  # 'A' padding past the 16KB buffer
    mp = mp + 18000;
    memcpy(mbuf + mp, "\"}", 2);
    mp = mp + 2;
    assert(file_write_all(mpath, mbuf, mp) == mp, "big_write");
    var bcfg = update_config_new();
    update_config_set_url(bcfg, "file:///tmp/agnos-update-bigmanifest.json");
    var bres = update_check(bcfg, "2026.1.0");
    assert(is_ok(bres) == 1, "big_check_ok");
    assert(payload(bres) != 0, "big_check_newer");
    sys_unlink(mpath);
    return 0;
}

# ================================================================
# bootloader (10 assertions)
# ================================================================

fn test_bootloader() {
    println("-- bootloader --");
    assert(is_ok(bootloader_validate_kernel_cmdline("root=/dev/sda1 ro")) == 1, "cmd_ok");
    assert(is_err_result(bootloader_validate_kernel_cmdline("root=/dev/sda1 init=/bin/sh")) == 1, "cmd_bad");
    assert(is_ok(bootloader_validate_kernel_cmdline("quiet splash")) == 1, "cmd_qs");
    assert(streq(bootloader_type_str(BOOT_SYSTEMD_BOOT), "systemd-boot") == 1, "bt_sd");
    assert(streq(bootloader_type_str(BOOT_GRUB2), "GRUB2") == 1, "bt_gr");
    var be = bootloader_entry_new();
    bootloader_entry_set_id(be, "arch");
    bootloader_entry_set_title(be, "Arch Linux");
    bootloader_entry_set_is_default(be, 1);
    assert(streq(bootloader_entry_id(be), "arch") == 1, "be_id");
    assert(streq(bootloader_entry_title(be), "Arch Linux") == 1, "be_t");
    assert_eq(bootloader_entry_is_default(be), 1, "be_d");
    var bc = bootloader_config_new();
    bootloader_config_set_type(bc, BOOT_SYSTEMD_BOOT);
    bootloader_config_set_timeout(bc, 5);
    assert_eq(bootloader_config_type(bc), BOOT_SYSTEMD_BOOT, "bc_t");
    assert_eq(bootloader_config_timeout(bc), 5, "bc_to");
    return 0;
}

# ================================================================
# audit (12 assertions)
# ================================================================

fn test_audit() {
    println("-- audit --");
    var r1 = audit_rule_file_watch("/etc/passwd", "pw");
    assert_eq(audit_rule_type(r1), AUDIT_RULE_FILE_WATCH, "fw_t");
    assert(streq(audit_rule_path(r1), "/etc/passwd") == 1, "fw_p");
    assert(streq(audit_rule_key(r1), "pw") == 1, "fw_k");
    assert(is_ok(audit_rule_validate(r1)) == 1, "fw_v");
    var r2 = audit_rule_syscall_watch(59, "ex");
    assert_eq(audit_rule_type(r2), AUDIT_RULE_SYSCALL_WATCH, "sw_t");
    assert_eq(audit_rule_syscall(r2), 59, "sw_nr");
    assert(is_ok(audit_rule_validate(r2)) == 1, "sw_v");
    var r3 = audit_rule_file_watch("../etc/passwd", "bad");
    assert(is_err_result(audit_rule_validate(r3)) == 1, "fw_trav");
    var r4 = audit_rule_file_watch("etc/passwd", "bad");
    assert(is_err_result(audit_rule_validate(r4)) == 1, "fw_rel");
    var st = audit_status_new();
    assert_eq(audit_status_enabled(st), 0, "as_en");
    assert_eq(audit_status_lost(st), 0, "as_lost");
    audit_status_set_enabled(st, 1);
    audit_status_set_pid(st, 42);
    var sb = str_builder_new();
    audit_status_to_json(st, sb);
    var json = str_builder_build(sb);
    var sb_exp = str_builder_new();
    str_builder_add_cstr(sb_exp, "{\"enabled\":1,\"failure_action\":1,\"pid\":42,");
    str_builder_add_cstr(sb_exp, "\"backlog_limit\":8192,\"lost\":0,\"backlog\":0}");
    assert(str_eq(json, str_builder_build(sb_exp)) == 1, "as_json");
    return 0;
}

# ================================================================
# pam (16 assertions)
# ================================================================

fn test_pam() {
    println("-- pam --");
    assert(is_ok(pam_validate_username("testuser")) == 1, "usr_ok");
    assert(is_ok(pam_validate_username("_svc")) == 1, "usr_usc");
    assert(is_err_result(pam_validate_username("")) == 1, "usr_empty");
    assert(streq(pam_service_name(PAM_SVC_LOGIN), "login") == 1, "svc_l");
    assert(streq(pam_service_name(PAM_SVC_SUDO), "sudo") == 1, "svc_s");
    assert(streq(pam_service_name(PAM_SVC_SSHD), "sshd") == 1, "svc_ss");
    assert(streq(pam_rule_type_name(PAM_TYPE_AUTH), "auth") == 1, "rt_a");
    assert(streq(pam_rule_type_name(PAM_TYPE_SESSION), "session") == 1, "rt_s");
    assert(streq(pam_control_name(PAM_CTL_REQUIRED), "required") == 1, "ctl_r");
    assert(streq(pam_control_name(PAM_CTL_OPTIONAL), "optional") == 1, "ctl_o");
    var rule = pam_rule_new(PAM_TYPE_AUTH, PAM_CTL_REQUIRED, "pam_unix.so", "");
    assert_eq(pam_rule_type(rule), PAM_TYPE_AUTH, "pr_t");
    assert_eq(pam_rule_control(rule), PAM_CTL_REQUIRED, "pr_c");
    var u = pam_user_alloc();
    pam_user_set(u, "alice", 1000, 1000, "/home/alice", "/bin/bash");
    assert_eq(pam_user_uid(u), 1000, "pu_uid");
    assert(streq(pam_user_username(u), "alice") == 1, "pu_n");

    # Regression (1.3.1): agnosys_read_fd_to_str (shared by the pam readers)
    # must not overflow when the file fills the buffer — the per-module copies
    # alloc'd `cap` and wrote the NUL at offset `cap`, one byte past the end.
    var rfpath = "/tmp/agnos-readfd-test";
    var rfbuf = alloc(100);
    memset(rfbuf, 65, 100);
    file_write_all(rfpath, rfbuf, 100);
    var rfd = sys_open(rfpath, 0, 0);
    var rfs = agnosys_read_fd_to_str(rfd, 50);
    sys_close(rfd);
    assert(str_len(rfs) == 50, "readfd_cap");
    sys_unlink(rfpath);
    return 0;
}

# ================================================================
# mac (5 assertions)
# ================================================================

fn test_mac() {
    println("-- mac --");
    var p = mac_default_profile("svc");
    assert(mac_profile_selinux_ctx(p) != 0, "sel");
    assert(mac_profile_apparmor_name(p) != 0, "aa");
    assert(streq(mac_profile_agent_type(p), "svc") == 1, "ma_at");
    var p2 = mac_profile_new("test");
    mac_profile_set_selinux_ctx(p2, "user:role:type:level");
    assert(streq(mac_profile_selinux_ctx(p2), "user:role:type:level") == 1, "mp_se");
    mac_profile_set_apparmor_name(p2, "test-profile");
    assert(streq(mac_profile_apparmor_name(p2), "test-profile") == 1, "mp_aa");
    var sb = str_builder_new();
    mac_profile_to_json(p2, sb);
    var json = str_builder_build(sb);
    var sb_exp = str_builder_new();
    str_builder_add_cstr(sb_exp, "{\"agent_type\":\"test\",\"selinux_ctx\":\"user:role:type:level\",");
    str_builder_add_cstr(sb_exp, "\"apparmor_name\":\"test-profile\"}");
    assert(str_eq(json, str_builder_build(sb_exp)) == 1, "mp_json");
    var p3 = mac_profile_new("min");
    var sb3 = str_builder_new();
    mac_profile_to_json(p3, sb3);
    var json3 = str_builder_build(sb3);
    var sb3_exp = str_builder_new();
    str_builder_add_cstr(sb3_exp, "{\"agent_type\":\"min\",\"selinux_ctx\":null,");
    str_builder_add_cstr(sb3_exp, "\"apparmor_name\":null}");
    assert(str_eq(json3, str_builder_build(sb3_exp)) == 1, "mp_json_null");
    return 0;
}

# ================================================================
# dmverity (8 assertions)
