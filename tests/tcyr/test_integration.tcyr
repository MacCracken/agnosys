# ================================================================
# netns (13 assertions)
# ================================================================

fn test_netns() {
    println("-- netns --");
    var c = netns_config_new("agent-1", "10.0.0.2", "10.0.0.1", 24, 1);
    assert(streq(netns_config_name(c), "agent-1") == 1, "nc_n");
    assert(streq(netns_config_agent_ip(c), "10.0.0.2") == 1, "nc_ai");
    assert_eq(netns_config_prefix_len(c), 24, "nc_pl");
    assert_eq(netns_config_enable_nat(c), 1, "nc_nat");
    var h = netns_handle_new("ns1", "veth-h", "veth-a", "/var/run/netns/ns1");
    assert(streq(netns_handle_name(h), "ns1") == 1, "nh_n");
    assert(streq(netns_handle_veth_host(h), "veth-h") == 1, "nh_vh");
    var fr = netns_fw_rule_new(TRAFFIC_INBOUND, PROTO_TCP, 443, "0.0.0.0", FW_ACCEPT, "https");
    assert_eq(netns_fw_rule_direction(fr), TRAFFIC_INBOUND, "fr_d");
    assert_eq(netns_fw_rule_protocol(fr), PROTO_TCP, "fr_p");
    assert_eq(netns_fw_rule_port(fr), 443, "fr_pt");
    assert_eq(netns_fw_rule_action(fr), FW_ACCEPT, "fr_a");
    var fp = netns_fw_policy_new(FW_DROP, FW_ACCEPT);
    assert_eq(netns_fw_policy_default_in(fp), FW_DROP, "fp_i");
    assert_eq(netns_fw_policy_default_out(fp), FW_ACCEPT, "fp_o");
    return 0;
}

# ================================================================
# journald (6 assertions)
# ================================================================

fn test_journald() {
    println("-- journald --");
    var e = journald_entry_new(170000, str_from("svc"), JOURNAL_INFO, str_from("hello"), 1234);
    assert_eq(journald_entry_timestamp(e), 170000, "je_ts");
    assert_eq(journald_entry_priority(e), JOURNAL_INFO, "je_pri");
    assert_eq(journald_entry_pid(e), 1234, "je_pid");
    var f = journald_filter_new();
    journald_filter_set_unit(f, "sshd.service");
    journald_filter_set_priority(f, JOURNAL_ERR);
    journald_filter_set_lines(f, 50);
    assert(streq(journald_filter_unit(f), "sshd.service") == 1, "jf_u");
    assert_eq(journald_filter_priority(f), JOURNAL_ERR, "jf_p");
    assert_eq(journald_filter_lines(f), 50, "jf_l");
    return 0;
}

