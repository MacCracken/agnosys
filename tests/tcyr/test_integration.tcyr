fn test_luks() {
    println("-- luks --");
    var cfg = luks_config_default("vol", "/tmp/t.img", "/mnt/t");
    assert(is_ok(luks_config_validate(cfg)) == 1, "cfg_v");
    assert(streq(luks_fs_as_str(LUKS_FS_EXT4), "ext4") == 1, "ext4");
    assert(streq(luks_fs_as_str(LUKS_FS_XFS), "xfs") == 1, "xfs");
    assert(streq(luks_fs_as_str(LUKS_FS_BTRFS), "btrfs") == 1, "btrfs");
    assert(streq(luks_pbkdf_as_str(LUKS_PBKDF_ARGON2ID), "argon2id") == 1, "argon");
    assert(streq(luks_pbkdf_as_str(LUKS_PBKDF_PBKDF2), "pbkdf2") == 1, "pbkdf");
    assert(streq(luks_config_name(cfg), "vol") == 1, "lc_n");
    assert_eq(luks_config_size_mb(cfg), LUKS_DEFAULT_SIZE_MB, "lc_sz");
    assert_eq(luks_is_name_char(97), 1, "nc_a");
    assert_eq(luks_is_name_char(33), 0, "nc_ex");
    return 0;
}

# ================================================================
# ima (10 assertions)
# ================================================================

fn test_ima() {
    println("-- ima --");
    assert(streq(ima_action_str(IMA_MEASURE), "measure") == 1, "act_m");
    assert(streq(ima_action_str(IMA_APPRAISE), "appraise") == 1, "act_a");
    assert(streq(ima_target_str(IMA_BPRM_CHECK), "BPRM_CHECK") == 1, "tgt_b");
    assert(streq(ima_target_str(IMA_FILE_CHECK), "FILE_CHECK") == 1, "tgt_f");
    var r = ima_rule_new(IMA_MEASURE, IMA_BPRM_CHECK);
    assert_eq(ima_rule_action(r), IMA_MEASURE, "ir_a");
    assert_eq(ima_rule_target(r), IMA_BPRM_CHECK, "ir_t");
    ima_rule_set_uid(r, 0);
    assert_eq(ima_rule_uid(r), 0, "ir_uid");
    ima_rule_set_fowner(r, 1000);
    assert_eq(ima_rule_fowner(r), 1000, "ir_fo");
    var st = ima_status_new(1, 42, 1);
    assert_eq(ima_status_active(st), 1, "is_a");
    assert_eq(ima_status_measurement_count(st), 42, "is_mc");
    return 0;
}

# ================================================================
# tpm (9 assertions)
# ================================================================

fn test_tpm() {
    println("-- tpm --");
    assert(tpm_detect() == 0 || tpm_detect() == 1, "tpm_d");
    assert(streq(tpm_bank_str(TPM_SHA1), "sha1") == 1, "bk_1");
    assert(streq(tpm_bank_str(TPM_SHA256), "sha256") == 1, "bk_256");
    assert(streq(tpm_bank_str(TPM_SHA512), "sha512") == 1, "bk_512");
    assert_eq(tpm_bank_hex_len(TPM_SHA256), TPM_SHA256_HEX_LEN, "hl_256");
    var pv = tpm_pcr_value_new(7, TPM_SHA256, "abcdef");
    assert_eq(tpm_pcr_value_index(pv), 7, "pv_i");
    assert_eq(tpm_pcr_value_bank(pv), TPM_SHA256, "pv_b");
    var ss = tpm_sealed_new("/tmp/ctx", "sha256:0,1,7");
    assert(streq(tpm_sealed_context(ss), "/tmp/ctx") == 1, "ss_c");
    return 0;
}

