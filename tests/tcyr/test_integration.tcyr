fn test_ima() {
    println("-- ima --");
    assert(streq(ima_action_str(IMA_MEASURE), "measure") == 1, "act_m");
    assert(streq(ima_action_str(IMA_APPRAISE), "appraise") == 1, "act_a");
    assert(streq(ima_target_str(IMA_BPRM_CHECK), "BPRM_CHECK") == 1, "tgt_b");
    assert(streq(ima_target_str(IMA_FILE_CHECK), "FILE_CHECK") == 1, "tgt_f");
    var r = ima_rule_new(IMA_MEASURE, IMA_BPRM_CHECK);
    assert_eq(ima_rule_action(r), IMA_MEASURE, "ir_a");
    assert_eq(ima_rule_target(r), IMA_BPRM_CHECK, "ir_t");
    ima_rule_set_uid(r, 0);
    assert_eq(ima_rule_uid(r), 0, "ir_uid");
    ima_rule_set_fowner(r, 1000);
    assert_eq(ima_rule_fowner(r), 1000, "ir_fo");
    var st = ima_status_new(1, 42, 1);
    assert_eq(ima_status_active(st), 1, "is_a");
    assert_eq(ima_status_measurement_count(st), 42, "is_mc");
    var sb = str_builder_new();
    ima_status_to_json(st, sb);
    var json = str_builder_build(sb);
    assert(str_eq_cstr(json, "{\"active\":1,\"measurement_count\":42,\"policy_loaded\":1}") == 1, "is_json");
    return 0;
}

# ================================================================
# tpm (9 assertions)
# ================================================================

fn test_tpm() {
    println("-- tpm --");
    assert(tpm_detect() == 0 || tpm_detect() == 1, "tpm_d");
    assert(streq(tpm_bank_str(TPM_SHA1), "sha1") == 1, "bk_1");
    assert(streq(tpm_bank_str(TPM_SHA256), "sha256") == 1, "bk_256");
    assert(streq(tpm_bank_str(TPM_SHA512), "sha512") == 1, "bk_512");
    assert_eq(tpm_bank_hex_len(TPM_SHA256), TPM_SHA256_HEX_LEN, "hl_256");
    var pv = tpm_pcr_value_new(7, TPM_SHA256, "abcdef");
    assert_eq(tpm_pcr_value_index(pv), 7, "pv_i");
    assert_eq(tpm_pcr_value_bank(pv), TPM_SHA256, "pv_b");
    var ss = tpm_sealed_new("/tmp/ctx", "sha256:0,1,7");
    assert(streq(tpm_sealed_context(ss), "/tmp/ctx") == 1, "ss_c");
    return 0;
}

# ================================================================
# secureboot (5 assertions)
# ================================================================

fn test_secureboot() {
    println("-- secureboot --");
    assert_eq(secureboot_is_enforcing(SB_ENABLED), 1, "sb_e");
    assert_eq(secureboot_is_enforcing(SB_DISABLED), 0, "sb_d");
    assert_eq(secureboot_is_enforcing(SB_SETUP_MODE), 0, "sb_sm");
    assert(streq(secureboot_state_str(SB_ENABLED), "enabled") == 1, "ss_e");
    assert(streq(secureboot_state_str(SB_DISABLED), "disabled") == 1, "ss_d");
    return 0;
}

# ================================================================
# fuse (4 assertions)
# ================================================================

fn test_fuse() {
    println("-- fuse --");
    assert_eq(fuse_starts_with("fuse.sshfs", "fuse"), 1, "f_h");
    assert_eq(fuse_starts_with("ext4", "fuse"), 0, "f_m");
    var m = fuse_mount_new("/dev/fuse", "/mnt/data", "fuse.sshfs", "rw");
    assert(streq(fuse_mount_device(m), "/dev/fuse") == 1, "fm_d");
    assert(streq(fuse_mount_mountpoint(m), "/mnt/data") == 1, "fm_m");
    # F-7 (1.1.14): /proc/mounts octal-escape unescape (\040 → space, etc.)
    var line1 = "device /mnt/with\\040space type rw 0 0";
    var f1 = fuse_extract_field(line1, strlen(line1), 1);
    assert(streq(f1, "/mnt/with space") == 1, "esc_space");
    var line2 = "src /mnt/path\\134escape ext4 rw 0 0";
    var f2 = fuse_extract_field(line2, strlen(line2), 1);
    assert(streq(f2, "/mnt/path\\escape") == 1, "esc_backslash");
    var line3 = "src /no/escape ext4 rw 0 0";
    var f3 = fuse_extract_field(line3, strlen(line3), 1);
    assert(streq(f3, "/no/escape") == 1, "esc_none");
    return 0;
}

# ================================================================
# udev (7 assertions)
# ================================================================

fn test_udev() {
    println("-- udev --");
    assert_eq(udev_parse_subsystem("block"), SUBSYS_BLOCK, "u_blk");
    assert_eq(udev_parse_subsystem("net"), SUBSYS_NET, "u_net");
    assert_eq(udev_parse_subsystem("input"), SUBSYS_INPUT, "u_inp");
    assert_eq(udev_parse_subsystem("usb"), SUBSYS_USB, "u_usb");
    assert_eq(udev_parse_subsystem("xxx"), SUBSYS_OTHER, "u_oth");
    var d = udev_devinfo_new();
    udev_devinfo_set_syspath(d, "/sys/devices/pci0");
    assert(streq(udev_devinfo_syspath(d), "/sys/devices/pci0") == 1, "ud_sp");
    udev_devinfo_set_driver(d, "e1000e");
    assert(streq(udev_devinfo_driver(d), "e1000e") == 1, "ud_dr");
    return 0;
}

# ================================================================
# drm (7 assertions)
# ================================================================

fn test_drm() {
    println("-- drm --");
    assert_eq(DRM_CAP_DUMB_BUFFER, 1, "drm_db");
    assert_eq(DRM_CAP_PRIME, 5, "drm_pr");
    var v = drm_verinfo_new(1, 2, 3, "amdgpu", "20230101", "AMD GPU");
    assert_eq(drm_verinfo_major(v), 1, "dv_ma");
    assert_eq(drm_verinfo_minor(v), 2, "dv_mi");
    assert_eq(drm_verinfo_patch(v), 3, "dv_pa");
    assert(streq(drm_verinfo_name(v), "amdgpu") == 1, "dv_n");
    assert(streq(drm_verinfo_desc(v), "AMD GPU") == 1, "dv_de");
    var sb = str_builder_new();
    drm_verinfo_to_json(v, sb);
    var json = str_builder_build(sb);
    var sb_exp = str_builder_new();
    str_builder_add_cstr(sb_exp, "{\"major\":1,\"minor\":2,\"patch\":3,");
    str_builder_add_cstr(sb_exp, "\"name\":\"amdgpu\",\"date\":\"20230101\",\"desc\":\"AMD GPU\"}");
    assert(str_eq(json, str_builder_build(sb_exp)) == 1, "dv_json");
    return 0;
}

# ================================================================
# netns (14 assertions)
# ================================================================

fn test_netns() {
    println("-- netns --");
    var c = netns_config_new("agent-1", "10.0.0.2", "10.0.0.1", 24, 1);
    assert(streq(netns_config_name(c), "agent-1") == 1, "nc_n");
    assert(streq(netns_config_agent_ip(c), "10.0.0.2") == 1, "nc_ai");
    assert_eq(netns_config_prefix_len(c), 24, "nc_pl");
    assert_eq(netns_config_enable_nat(c), 1, "nc_nat");
    var h = netns_handle_new("ns1", "veth-h", "veth-a", "/var/run/netns/ns1");
    assert(streq(netns_handle_name(h), "ns1") == 1, "nh_n");
    assert(streq(netns_handle_veth_host(h), "veth-h") == 1, "nh_vh");
    var fr = netns_fw_rule_new(TRAFFIC_INBOUND, PROTO_TCP, 443, "0.0.0.0", FW_ACCEPT, "https");
    assert_eq(netns_fw_rule_direction(fr), TRAFFIC_INBOUND, "fr_d");
    assert_eq(netns_fw_rule_protocol(fr), PROTO_TCP, "fr_p");
    assert_eq(netns_fw_rule_port(fr), 443, "fr_pt");
    assert_eq(netns_fw_rule_action(fr), FW_ACCEPT, "fr_a");
    var fp = netns_fw_policy_new(FW_DROP, FW_ACCEPT);
    assert_eq(netns_fw_policy_default_in(fp), FW_DROP, "fp_i");
    assert_eq(netns_fw_policy_default_out(fp), FW_ACCEPT, "fp_o");

    # Regression (1.3.0): netns command exec was broken — the argv array was
    # passed as a single argument to run_capture/_exec3 (cmd + 2 args max),
    # so multi-arg `ip netns add ...` never reached the binary. netns now
    # builds a cstr vec and runs it via exec_vec, which NULL-terminates a
    # real argv and execve's an absolute path. The privileged `ip` path
    # needs CAP_NET_ADMIN, so guard the mechanism netns depends on with a
    # rootless absolute-path command carrying two args past argv[0].
    var ed = "/tmp/agnos-netns-exec-test/sub";
    var margs = vec_new();
    vec_push(margs, "/usr/bin/mkdir");
    vec_push(margs, "-p");
    vec_push(margs, ed);
    exec_vec(margs);
    assert(sys_access(ed, 0) == 0, "exec_vec_multiarg");
    sys_rmdir("/tmp/agnos-netns-exec-test/sub");
    sys_rmdir("/tmp/agnos-netns-exec-test");
    return 0;
}

# ================================================================
# journald (6 assertions)
# ================================================================

fn test_journald() {
    println("-- journald --");
    var e = journald_entry_new(170000, str_from("svc"), JOURNAL_INFO, str_from("hello"), 1234);
    assert_eq(journald_entry_timestamp(e), 170000, "je_ts");
    assert_eq(journald_entry_priority(e), JOURNAL_INFO, "je_pri");
    assert_eq(journald_entry_pid(e), 1234, "je_pid");
    var f = journald_filter_new();
    journald_filter_set_unit(f, "sshd.service");
    journald_filter_set_priority(f, JOURNAL_ERR);
    journald_filter_set_lines(f, 50);
    assert(streq(journald_filter_unit(f), "sshd.service") == 1, "jf_u");
    assert_eq(journald_filter_priority(f), JOURNAL_ERR, "jf_p");
    assert_eq(journald_filter_lines(f), 50, "jf_l");
    return 0;
}

# ================================================================
# audit regressions (12 assertions) — pinned exploit vectors from
# the 2026-04-26 P(-1) audit. Fuzz harnesses cover input families;
# these assertions pin the specific behaviors so a future refactor
# can't silently undo a finding's fix.
# ================================================================

fn test_audit_regressions() {
    println("-- audit regressions --");

    # F-1 — journald filter values must round-trip verbatim through
    # set/get. The whole point of the argv-based exec rewrite is that
    # shell metacharacters land in argv[i] unchanged for journalctl
    # to consume verbatim. If a setter ever starts escaping or
    # splitting, this breaks first.
    var f = journald_filter_new();
    var hostile = "; rm -rf /; #";
    journald_filter_set_grep(f, hostile);
    assert(streq(journald_filter_grep(f), hostile) == 1, "f1_grep_verbatim");
    journald_filter_set_unit(f, "sshd.service; touch /tmp/pwn");
    assert(streq(journald_filter_unit(f), "sshd.service; touch /tmp/pwn") == 1, "f1_unit_verbatim");

    # F-2 — LUKS cipher allowlist. cipher_null and any "null" substring
    # (case-insensitive) must reject; off-allowlist algos/modes must
    # reject; the four allowed algos × four allowed modes must accept.
    assert(is_err_result(luks_validate_cipher("cipher_null", "ecb")) == 1, "f2_null_lower");
    assert(is_err_result(luks_validate_cipher("Cipher_Null", "ecb")) == 1, "f2_null_mixed");
    assert(is_err_result(luks_validate_cipher("aes", "xts-NULL")) == 1, "f2_null_in_mode");
    assert(is_err_result(luks_validate_cipher("chacha20", "xts-plain64")) == 1, "f2_off_algo");
    assert(is_err_result(luks_validate_cipher("aes", "ecb")) == 1, "f2_off_mode");
    assert(is_ok(luks_validate_cipher("aes", "xts-plain64")) == 1, "f2_aes_xts");
    assert(is_ok(luks_validate_cipher("serpent", "cbc-essiv:sha256")) == 1, "f2_serpent_cbc");

    # F-3 — LUKS keyfile path must include the /tmp/.agnos-luks- prefix
    # AND two consecutive calls must return distinct paths (the random
    # 16-hex suffix from getrandom defeats prediction). If getrandom
    # ever degrades to fixed bytes, both calls return the same string.
    var p1_res = luks_keyfile_path();
    assert(is_ok(p1_res) == 1, "f3_p1_ok");
    var p1 = payload(p1_res);
    var p2_res = luks_keyfile_path();
    assert(is_ok(p2_res) == 1, "f3_p2_ok");
    var p2 = payload(p2_res);
    assert(streq(p1, p2) == 0, "f3_unique");

    return 0;
}

# ================================================================
# edge cases (24 assertions) — boundary/error paths that the
# per-module tests above don't reach, validated pre-1.0 freeze.
# ================================================================

fn test_edge_cases() {
    println("-- edge cases --");

    # update_validate_version — year/month boundaries
    assert(is_ok(update_validate_version("2024.1.1")) == 1, "uvv_lo_y");
    assert(is_ok(update_validate_version("2100.12.31")) == 1, "uvv_hi_y");
    assert(is_err_result(update_validate_version("2023.6.1")) == 1, "uvv_u_y");
    assert(is_err_result(update_validate_version("2101.6.1")) == 1, "uvv_o_y");
    assert(is_err_result(update_validate_version("2025.0.1")) == 1, "uvv_u_m");
    assert(is_err_result(update_validate_version("2025.13.1")) == 1, "uvv_o_m");

    # update_compare_versions — both-malformed falls through to lex compare
    assert_eq(update_compare_versions("abc", "abd"), VER_LESS, "ucv_lex_l");
    assert_eq(update_compare_versions("abc", "abc"), VER_EQUAL, "ucv_lex_eq");
    assert_eq(update_compare_versions("abcd", "abc"), VER_GREATER, "ucv_lex_g");

    # pam_validate_username — length + first-char + body-char rules
    assert(is_ok(pam_validate_username("aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")) == 1, "usr_32");  # 32 chars
    assert(is_err_result(pam_validate_username("aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")) == 1, "usr_33");  # 33 chars
    assert(is_err_result(pam_validate_username("1abc")) == 1, "usr_digit_first");
    assert(is_err_result(pam_validate_username("Alice")) == 1, "usr_upper");
    assert(is_err_result(pam_validate_username("bad name")) == 1, "usr_space");
    assert(is_err_result(pam_validate_username("root$")) == 1, "usr_dollar");

    # bootloader_validate_kernel_cmdline — known-dangerous tokens
    assert(is_err_result(bootloader_validate_kernel_cmdline("root=/dev/sda1 rd.break")) == 1, "cmd_rdbrk");
    assert(is_err_result(bootloader_validate_kernel_cmdline("root=/dev/sda1 single")) == 1, "cmd_single");
    bootloader_danger_reset();

    # certpin_validate_pin_format — length boundaries (44 exactly required)
    assert_eq(certpin_validate_pin_format("AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"), 0, "pin_43");    # 43
    assert_eq(certpin_validate_pin_format("AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"), 0, "pin_45"); # 45
    assert_eq(certpin_validate_pin_format("AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"), 1, "pin_44"); # 44 all A
    assert_eq(certpin_validate_pin_format("AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA#AAAA"), 0, "pin_bad_ch"); # bad byte

    # err_from_errno — distinct errno values map to distinct error kinds
    var e_perm = err_from_errno(EPERM);
    var e_inval = err_from_errno(EINVAL);
    assert(is_err_result(e_perm) == 1, "efe_perm");
    assert(is_err_result(e_inval) == 1, "efe_inval");
    assert(syserr_errno(payload(e_perm)) == EPERM, "efe_perm_e");
    assert(syserr_errno(payload(e_inval)) == EINVAL, "efe_inval_e");

    return 0;
}

