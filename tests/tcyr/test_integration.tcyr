fn test_mac() {
    println("-- mac --");
    var p = mac_default_profile("svc");
    assert(mac_profile_selinux_ctx(p) != 0, "sel");
    assert(mac_profile_apparmor_name(p) != 0, "aa");
    assert(streq(mac_profile_agent_type(p), "svc") == 1, "ma_at");
    var p2 = mac_profile_new("test");
    mac_profile_set_selinux_ctx(p2, "user:role:type:level");
    assert(streq(mac_profile_selinux_ctx(p2), "user:role:type:level") == 1, "mp_se");
    mac_profile_set_apparmor_name(p2, "test-profile");
    assert(streq(mac_profile_apparmor_name(p2), "test-profile") == 1, "mp_aa");
    return 0;
}

# ================================================================
# dmverity (8 assertions)
# ================================================================

fn test_dmverity() {
    println("-- dmverity --");
    var h = "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa";
    assert(is_ok(dmverity_validate_root_hash(h, VERITY_SHA256)) == 1, "h_ok");
    assert(is_err_result(dmverity_validate_root_hash("short", VERITY_SHA256)) == 1, "h_short");
    assert(is_err_result(dmverity_validate_root_hash("", VERITY_SHA256)) == 1, "h_empty");
    assert(streq(dmverity_hash_algo_str(VERITY_SHA256), "sha256") == 1, "a256");
    assert_eq(dmverity_hash_hex_len(VERITY_SHA256), 64, "hl256");
    var st = dmverity_status_new("test-vol", 1, 1, 0, h);
    assert(streq(dmverity_status_name(st), "test-vol") == 1, "vs_n");
    assert_eq(dmverity_status_is_active(st), 1, "vs_a");
    assert_eq(dmverity_status_corruption_detected(st), 0, "vs_c");
    return 0;
}

