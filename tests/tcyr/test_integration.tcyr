fn test_secureboot() {
    println("-- secureboot --");
    assert_eq(secureboot_is_enforcing(SB_ENABLED), 1, "sb_e");
    assert_eq(secureboot_is_enforcing(SB_DISABLED), 0, "sb_d");
    assert_eq(secureboot_is_enforcing(SB_SETUP_MODE), 0, "sb_sm");
    assert(streq(secureboot_state_str(SB_ENABLED), "enabled") == 1, "ss_e");
    assert(streq(secureboot_state_str(SB_DISABLED), "disabled") == 1, "ss_d");
    return 0;
}

