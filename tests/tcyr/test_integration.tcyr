# ================================================================
# error (27 assertions)
# ================================================================

fn test_error() {
    println("-- error --");
    assert_eq(syserr_kind(syserr_pack(ERR_SYSCALL_FAILED, EPERM)), ERR_SYSCALL_FAILED, "pack_k");
    assert_eq(syserr_errno(syserr_pack(ERR_SYSCALL_FAILED, EPERM)), EPERM, "pack_e");
    assert_eq(syserr_kind(syserr_pack(ERR_IO, EIO)), ERR_IO, "pack_io_k");
    assert_eq(syserr_errno(syserr_pack(ERR_IO, EIO)), EIO, "pack_io_e");
    assert_eq(syserr_kind(syserr_pack(ERR_PERMISSION_DENIED, EACCES)), ERR_PERMISSION_DENIED, "pack_pd");
    var h = syserr_new(ERR_IO, EIO, "test");
    assert_eq(syserr_kind(h), ERR_IO, "heap_k");
    assert_eq(syserr_errno(h), EIO, "heap_e");
    assert(syserr_message(h) != 0, "heap_m");
    assert_eq(is_syscall_err(0 - 1), 1, "err_neg");
    assert_eq(is_syscall_err(0 - 999), 1, "err_neg2");
    assert_eq(is_syscall_err(0), 0, "err_zero");
    assert_eq(is_syscall_err(1), 0, "err_pos");
    assert(is_ok(wrap_syscall(42)) == 1, "wrap_ok");
    assert_eq(payload(wrap_syscall(42)), 42, "wrap_v");
    assert(is_err_result(wrap_syscall(0 - 1)) == 1, "wrap_e");
    assert(is_ok(wrap_syscall(0)) == 1, "wrap_0");
    assert(is_err_result(err_from_errno(EPERM)) == 1, "errno_perm");
    assert(is_err_result(err_from_errno(EACCES)) == 1, "errno_acces");
    assert(is_err_result(err_from_errno(EINVAL)) == 1, "errno_inval");
    assert(is_err_result(err_from_errno(ENOSYS)) == 1, "errno_nosys");
    assert(is_err_result(err_invalid_argument("x")) == 1, "eia");
    assert(is_err_result(err_permission_denied("x")) == 1, "epd");
    assert(is_err_result(err_not_supported("x")) == 1, "ens");
    assert(is_err_result(err_unknown("x")) == 1, "euk");
    assert(is_err_result(err_io(EIO, "x")) == 1, "eio");
    assert(is_err_result(err_module_not_loaded("x")) == 1, "eml");
    return 0;
}

# ================================================================
# syscall (11 assertions)
# ================================================================

fn test_syscall() {
    println("-- syscall --");
    assert_eq(agnosys_getpid(), agnosys_getpid(), "pid_eq");
    assert_gt(agnosys_getpid(), 0, "pid_pos");
    assert_gt(agnosys_gettid(), 0, "tid_pos");
    var euid = agnosys_geteuid();
    if (euid == 0) { assert_eq(agnosys_is_root(), 1, "root_y"); }
    else { assert_eq(agnosys_is_root(), 0, "root_n"); }
    var sibuf[120];
    var sres = query_sysinfo(&sibuf);
    assert(is_ok(sres) == 1, "sysinfo");
    var info = payload(sres);
    assert_gt(sysinfo_uptime(info), 0, "uptime");
    assert_gt(sysinfo_total_memory(info), 0, "ram");
    assert_gt(sysinfo_procs(info), 0 - 1, "procs");
    assert(is_ok(agnosys_checked_syscall(0)) == 1, "chk_ok");
    assert(is_err_result(agnosys_checked_syscall(0 - 1)) == 1, "chk_err");
    assert_eq(payload(agnosys_checked_syscall(42)), 42, "chk_v");
    return 0;
}

# ================================================================
# logging (7 assertions)
