# bench_all.cyr — comprehensive batch-amortized benchmarks
# 12 agnosys modules, batch timing (10K iters x 100 rounds)
#
# Build: cyrb build tests/bench_all.cyr build/bench_all
# Run:   ./build/bench_all

#define LINUX

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/tagged.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/process.cyr"
include "lib/fs.cyr"
include "lib/bench.cyr"

include "src/error.cyr"
include "src/syscall.cyr"
include "src/logging.cyr"
include "src/security.cyr"
include "src/certpin.cyr"
include "src/secureboot.cyr"
include "src/bootloader.cyr"
include "src/update.cyr"
include "src/mac.cyr"
include "src/fuse.cyr"
include "src/udev.cyr"

fn batch_record(b, elapsed, iters) {
    var per_op = elapsed / iters;
    store64(b + 16, load64(b + 16) + elapsed);
    store64(b + 24, load64(b + 24) + iters);
    if (per_op < load64(b + 32)) { store64(b + 32, per_op); }
    if (per_op > load64(b + 40)) { store64(b + 40, per_op); }
    return 0;
}

fn do_bench(name) { return bench_new(name); }

# ================================================================
# 1. syscall
# ================================================================

fn bench_syscalls() {
    println("-- syscall --");
    var b = do_bench("getpid");
    var ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { agnosys_getpid(); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("getuid");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { agnosys_getuid(); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("is_root");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { agnosys_is_root(); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("query_sysinfo");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 5000) { query_sysinfo(); k = k + 1; }
        batch_record(b, now_ns() - start, 5000);
        ri = ri + 1;
    }
    bench_report(b);

    return 0;
}

# ================================================================
# 2. error
# ================================================================

fn bench_errors() {
    println("-- error --");
    var b = do_bench("syserr_pack");
    var ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { syserr_pack(ERR_SYSCALL_FAILED, EPERM); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("from_errno_eperm");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { err_from_errno(EPERM); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("ok_create");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { Ok(42); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("wrap_syscall_ok");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { wrap_syscall(agnosys_getpid()); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    return 0;
}

