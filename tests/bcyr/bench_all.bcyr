# ================================================================
# 11. string / stdlib
# ================================================================

fn bench_strings() {
    println("-- string --");
    var b = do_bench("streq_16ch");
    var ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { streq("hello_world_test", "hello_world_test"); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("strlen_16ch");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { strlen("hello_world_test"); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("memeq_16");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { memeq("hello_world_test", "hello_world_test", 16); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    alloc_reset();
    alloc_init();
    var m = map_new();
    map_set(m, "key1", 42);

    b = do_bench("map_get_hit");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { map_get(m, "key1"); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("map_get_miss");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { map_get(m, "nonexistent"); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    return 0;
}

# ================================================================
# Main
# ================================================================

fn main() {
    alloc_init();
    println("================================================================");
    println("  agnosys bench — 12 modules, batch-amortized (10K x 100)");
    println("================================================================");

    bench_syscalls();

    alloc_reset(); alloc_init();
    bench_errors();

    alloc_reset(); alloc_init();
    bench_security();

    alloc_reset(); alloc_init();
    bench_certpin();

    alloc_reset(); alloc_init();
    bench_bootloader();

    alloc_reset(); alloc_init();
    bench_updates();

    alloc_reset(); alloc_init();
    bench_mac();

    alloc_reset(); alloc_init();
    bench_secureboot();

    alloc_reset(); alloc_init();
    bench_udev();

    alloc_reset(); alloc_init();
    bench_fuse();

    alloc_reset(); alloc_init();
    bench_strings();

    println("");
    println("================================================================");
    println("  done — 11 groups, 30 benchmarks");
    println("================================================================");
    return 0;
}

var r = main();
syscall(SYS_EXIT, r);
