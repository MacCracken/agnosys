# ================================================================
# 4. certpin
# ================================================================

fn bench_certpin() {
    println("-- certpin --");
    var pin = "YLh1dUR9y6Kja30RrAn7JKnbQG/uEtLMkBgFF2Fuihg=";
    var other = "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=";

    var b = do_bench("validate_pin_valid");
    var ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { certpin_validate_pin_format(pin); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("validate_pin_invalid");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { certpin_validate_pin_format("bad"); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("ct_streq_equal");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { certpin_ct_streq(pin, pin); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("ct_streq_diff");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { certpin_ct_streq(pin, other); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    return 0;
}

# ================================================================
# 5. bootloader
# ================================================================

fn bench_bootloader() {
    println("-- bootloader --");
    var safe = "root=/dev/sda1 ro quiet splash";
    var bad = "root=/dev/sda1 init=/bin/sh";
    var textlen = strlen(safe);

    var b = do_bench("validate_cmdline_safe");
    var ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { bootloader_validate_kernel_cmdline(safe); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("is_dangerous_token_hit");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        var badlen = strlen(bad);
        while (k < 10000) { bootloader_is_dangerous_token(bad, badlen, "init=/bin/sh"); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    b = do_bench("is_dangerous_token_miss");
    ri = 0;
    while (ri < 100) {
        var start = now_ns();
        var k = 0;
        while (k < 10000) { bootloader_is_dangerous_token(safe, textlen, "emergency"); k = k + 1; }
        batch_record(b, now_ns() - start, 10000);
        ri = ri + 1;
    }
    bench_report(b);

    return 0;
}

