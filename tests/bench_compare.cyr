# bench_compare.cyr — benchmark agnosys Cyrius operations
# Compares key operation timings for Rust-vs-Cyrius reporting
#
# Build: cyrb build tests/bench_compare.cyr build/bench_compare
# Run:   ./build/bench_compare

#define LINUX

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/tagged.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/process.cyr"
include "lib/fs.cyr"
include "lib/bench.cyr"

include "src/error.cyr"
include "src/syscall.cyr"
include "src/security.cyr"

# ================================================================
# Benchmark helpers
# ================================================================

fn bench_loop(name, iterations) {
    var b = bench_new(name);
    store64(b + 32, iterations);
    return b;
}

fn report(name, total_ns, iterations) {
    var per_op = total_ns / iterations;
    syscall(1, 1, name, strlen(name));
    syscall(1, 1, ": ", 2);
    print_num(per_op);
    syscall(1, 1, " ns/op (", 8);
    print_num(iterations);
    syscall(1, 1, " iters, ", 8);
    print_num(total_ns / 1000000);
    syscall(1, 1, " ms total)\n", 11);
    return 0;
}

# ================================================================
# Benchmarks
# ================================================================

fn bench_getpid() {
    var iters = 1000000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        var p = agnosys_getpid();
        k = k + 1;
    }
    var elapsed = now_ns() - start;
    report("getpid", elapsed, iters);
    return 0;
}

