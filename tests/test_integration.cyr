fn test_error() {
    println("-- error --");
    assert(is_err_result(err_from_errno(EPERM)) == 1, "errno_perm");
    assert_eq(syserr_kind(syserr_pack(ERR_SYSCALL_FAILED, EPERM)), ERR_SYSCALL_FAILED, "pack_k");
    assert_eq(syserr_errno(syserr_pack(ERR_SYSCALL_FAILED, EPERM)), EPERM, "pack_e");
    var h = syserr_new(ERR_IO, EIO, "err");
    assert_eq(syserr_kind(h), ERR_IO, "heap_k");
    assert(syserr_message(h) != 0, "heap_m");
    assert_eq(is_syscall_err(0 - 1), 1, "err_neg");
    assert_eq(is_syscall_err(0), 0, "err_zero");
    assert(is_ok(wrap_syscall(42)) == 1, "wrap_ok");
    assert_eq(payload(wrap_syscall(42)), 42, "wrap_v");
    assert(is_err_result(wrap_syscall(0 - 1)) == 1, "wrap_e");
    return 0;
}

fn test_syscall() {
    println("-- syscall --");
    assert_eq(agnosys_getpid(), agnosys_getpid(), "pid_eq");
    assert_gt(agnosys_getpid(), 0, "pid_pos");
    assert_gt(agnosys_gettid(), 0, "tid_pos");
    var euid = agnosys_geteuid();
    if (euid == 0) { assert_eq(agnosys_is_root(), 1, "root_y"); }
    else { assert_eq(agnosys_is_root(), 0, "root_n"); }
    var info = query_sysinfo();
    assert_gt(sysinfo_uptime(info), 0, "uptime");
    assert_gt(sysinfo_total_memory(info), 32 * 1024 * 1024, "ram");
    return 0;
}

fn test_security() {
    println("-- security --");
    assert(is_ok(create_basic_seccomp_filter()) == 1, "seccomp");
    assert_eq(syscall_name_to_nr("read"), 0, "nr_read");
    assert_eq(syscall_name_to_nr("write"), 1, "nr_write");
    assert_eq(syscall_name_to_nr("getpid"), 39, "nr_pid");
    assert_eq(syscall_name_to_nr("exit"), 60, "nr_exit");
    assert_eq(syscall_name_to_nr("xxx"), 0 - 1, "nr_miss");
    assert_eq(fs_rule_access(fs_rule_read_only("/t")), FS_READ_ONLY, "fs_ro");
    return 0;
}

fn test_certpin() {
    println("-- certpin --");
    var p = "YLh1dUR9y6Kja30RrAn7JKnbQG/uEtLMkBgFF2Fuihg=";
    assert_eq(certpin_validate_pin_format(p), 1, "pin_ok");
    assert_eq(certpin_validate_pin_format("bad"), 0, "pin_bad");
    assert_eq(certpin_ct_streq(p, p), 1, "ct_eq");
    assert_eq(certpin_ct_streq(p, "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="), 0, "ct_ne");
    var e = certpin_entry_new("x", 1700000000);
    assert_eq(certpin_check_pin_expiry(e, 1600000000), 0, "not_exp");
    assert_eq(certpin_check_pin_expiry(e, 1800000000), 1, "exp");
    return 0;
}

fn test_update() {
    println("-- update --");
    assert(is_ok(update_validate_version("2025.3.1")) == 1, "v_good");
    assert(is_err_result(update_validate_version("")) == 1, "v_bad");
    assert_eq(update_compare_versions("2025.1.0", "2025.2.0"), VER_LESS, "less");
    assert_eq(update_compare_versions("2025.3.0", "2025.3.0"), VER_EQUAL, "equal");
    assert_eq(update_other_slot(SLOT_A), SLOT_B, "sl_a");
    assert_eq(update_other_slot(SLOT_B), SLOT_A, "sl_b");
    return 0;
}

fn test_bootloader() {
    println("-- bootloader --");
    assert(is_ok(bootloader_validate_kernel_cmdline("root=/dev/sda1 ro")) == 1, "cmd_ok");
    assert(is_err_result(bootloader_validate_kernel_cmdline("root=/dev/sda1 init=/bin/sh")) == 1, "cmd_bad");
    return 0;
}

fn test_audit() {
    println("-- audit --");
    var r1 = audit_rule_file_watch("/etc/passwd", "pw");
    assert_eq(audit_rule_type(r1), AUDIT_RULE_FILE_WATCH, "fw_t");
    assert(is_ok(audit_rule_validate(r1)) == 1, "fw_v");
    var r2 = audit_rule_syscall_watch(59, "ex");
    assert_eq(audit_rule_type(r2), AUDIT_RULE_SYSCALL_WATCH, "sw_t");
    assert(is_ok(audit_rule_validate(r2)) == 1, "sw_v");
    return 0;
}

fn test_pam() {
    println("-- pam --");
    assert(is_ok(pam_validate_username("testuser")) == 1, "usr_ok");
    assert(is_err_result(pam_validate_username("")) == 1, "usr_bad");
    assert(streq(pam_service_name(PAM_SVC_LOGIN), "login") == 1, "svc");
    return 0;
}

fn test_mac() {
    println("-- mac --");
    var p = mac_default_profile("svc");
    assert(mac_profile_selinux_ctx(p) != 0, "sel");
    assert(mac_profile_apparmor_name(p) != 0, "aa");
    return 0;
}

fn test_dmverity() {
    println("-- dmverity --");
    var h = "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa";
    assert(is_ok(verity_validate_root_hash(h, VERITY_SHA256)) == 1, "h_ok");
    assert(is_err_result(verity_validate_root_hash("short", VERITY_SHA256)) == 1, "h_bad");
    assert(streq(verity_hash_algo_str(VERITY_SHA256), "sha256") == 1, "a256");
    return 0;
}

fn test_luks() {
    println("-- luks --");
    var cfg = luks_config_default("v", "/tmp/t.img", "/mnt/t");
    assert(is_ok(luks_config_validate(cfg)) == 1, "cfg");
    assert(streq(luks_fs_as_str(LUKS_FS_EXT4), "ext4") == 1, "ext4");
    return 0;
}

fn test_ima() {
    println("-- ima --");
    assert(streq(ima_action_str(IMA_MEASURE), "measure") == 1, "act");
    assert(streq(ima_target_str(IMA_BPRM_CHECK), "BPRM_CHECK") == 1, "tgt");
    var r = ima_rule_new(IMA_MEASURE, IMA_BPRM_CHECK);
    ima_rule_set_uid(r, 0);
    assert_eq(ima_rule_uid(r), 0, "uid");
    return 0;
}

fn test_remaining() {
    println("-- tpm --");
    assert(tpm_detect() == 0 || tpm_detect() == 1, "tpm");
    assert(streq(tpm_bank_str(TPM_SHA256), "sha256") == 1, "bank");

    println("-- secureboot --");
    assert_eq(secureboot_is_enforcing(SB_ENABLED), 1, "sb_e");
    assert_eq(secureboot_is_enforcing(SB_DISABLED), 0, "sb_d");

    println("-- fuse --");
    assert_eq(fuse_starts_with("fuse.sshfs", "fuse"), 1, "f_h");
    assert_eq(fuse_starts_with("ext4", "fuse"), 0, "f_m");

    println("-- udev --");
    assert_eq(udev_parse_subsystem("block"), SUBSYS_BLOCK, "u_b");
    assert_eq(udev_parse_subsystem("net"), SUBSYS_NET, "u_n");

    println("-- netns --");
    var c = netns_config_new("t", "10.0.0.2", "10.0.0.1", 24, 1);
    assert(streq(netns_config_name(c), "t") == 1, "ns");

    println("-- journald --");
    var e = journal_entry_new(170000, str_from("s"), JOURNAL_INFO, str_from("h"), 1234);
    assert_eq(journal_entry_priority(e), JOURNAL_INFO, "jp");
    assert_eq(journal_entry_pid(e), 1234, "jpid");

    println("-- drm --");
    # DRM tests are hardware-dependent, just verify constants
    assert_eq(DRM_CAP_DUMB_BUFFER, 1, "drm_c");
    return 0;
}

fn main() {
    alloc_init();
    println("================================================================");
    println("  agnosys integration tests — all 20 modules");
    println("================================================================");
    test_error();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_syscall();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_security();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_certpin();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_update();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_bootloader();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_audit();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_pam();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_mac();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_dmverity();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_luks();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_ima();
    syscall_map_reset(); bootloader_danger_reset(); alloc_reset(); alloc_init();
    test_remaining();
    println("");
    var f = assert_summary();
    if (f > 0) { return 1; }
    return 0;
}
var r = main();
syscall(SYS_EXIT, r);
