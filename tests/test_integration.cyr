# test_integration.cyr — integration tests for all 20 agnosys modules
# Parity target: rust-old/tests/integration.rs
#
# Build: cyrb build tests/test_integration.cyr build/test_integration
# Run:   ./build/test_integration

#define LINUX

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
