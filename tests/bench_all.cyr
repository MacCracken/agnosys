# ================================================================
# 18. string / stdlib group
# ================================================================

fn bench_string_group() {
    section("string");
    var iters = 1000000;

    # streq — equal
    var b = bench_new("streq_16ch_equal");
    var k = 0;
    while (k < iters) {
        bench_start(b);
        streq("hello_world_test", "hello_world_test");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # streq — not equal
    b = bench_new("streq_16ch_diff");
    k = 0;
    while (k < iters) {
        bench_start(b);
        streq("hello_world_test", "hello_world_xxxx");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # strlen
    b = bench_new("strlen_16ch");
    k = 0;
    while (k < iters) {
        bench_start(b);
        strlen("hello_world_test");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # memeq
    b = bench_new("memeq_16");
    k = 0;
    while (k < iters) {
        bench_start(b);
        memeq("hello_world_test", "hello_world_test", 16);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # str_contains
    alloc_reset();
    alloc_init();
    var haystack = str_from("the quick brown fox jumps over the lazy dog");
    b = bench_new("str_contains_hit");
    k = 0;
    while (k < 500000) {
        bench_start(b);
        str_contains(haystack, "lazy");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    b = bench_new("str_contains_miss");
    k = 0;
    while (k < 500000) {
        bench_start(b);
        str_contains(haystack, "zzz");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # hashmap set/get
    alloc_reset();
    alloc_init();
    var m = map_new();
    map_set(m, "key1", 42);
    b = bench_new("map_get_hit");
    k = 0;
    while (k < 500000) {
        bench_start(b);
        map_get(m, "key1");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    b = bench_new("map_get_miss");
    k = 0;
    while (k < 500000) {
        bench_start(b);
        map_get(m, "nonexistent");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    return 0;
}

# ================================================================
# Main
# ================================================================

fn main() {
    alloc_init();

    println("================================================================");
    println("  agnosys benchmark suite — all modules");
    println("  Cyrius port parity with rust-old/benches/benchmarks.rs");
    println("================================================================");

    bench_syscall_group();

    alloc_reset();
    alloc_init();
    bench_syscall_group_alloc();

    alloc_reset();
    alloc_init();
    bench_error_group();

    alloc_reset();
    alloc_init();
    bench_certpin_group();

    alloc_reset();
    alloc_init();
    bench_logging_group();

    alloc_reset();
    alloc_init();
    bench_update_group();

    alloc_reset();
    alloc_init();
    bench_secureboot_group();

    alloc_reset();
    alloc_init();
    bench_string_group();

    println("");
    println("================================================================");
    println("  done — 7 groups");
    println("================================================================");

    return 0;
}

var r = main();
syscall(SYS_EXIT, r);
