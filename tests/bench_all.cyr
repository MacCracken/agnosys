    bench_report(b);

    # log_level_prefix
    b = bench_new("log_level_prefix");
    k = 0;
    while (k < iters) {
        bench_start(b);
        log_level_prefix(LOG_INFO);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # log_msg (suppressed — level below threshold)
    log_set_level(LOG_ERROR);
    b = bench_new("log_msg_suppressed");
    k = 0;
    while (k < iters) {
        bench_start(b);
        log_msg(LOG_DEBUG, "suppressed message");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    return 0;
}

# ================================================================
# 6. update group
# ================================================================

fn bench_update_group() {
    section("update");
    var iters = 500000;

    # validate_version — good
    var b = bench_new("validate_version_good");
    var k = 0;
    while (k < iters) {
        bench_start(b);
        update_validate_version("2025.3.1");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # validate_version — bad
    b = bench_new("validate_version_bad");
    k = 0;
    while (k < iters) {
        bench_start(b);
        update_validate_version("");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # compare_versions
    alloc_reset();
    alloc_init();
    b = bench_new("compare_versions");
    k = 0;
    while (k < iters) {
        bench_start(b);
        update_compare_versions("2025.1.0", "2025.2.0");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # slot_other
    b = bench_new("slot_other");
    k = 0;
    while (k < 1000000) {
        bench_start(b);
        update_other_slot(SLOT_A);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # phase_str
    b = bench_new("phase_str");
    k = 0;
    while (k < 1000000) {
        bench_start(b);
        update_phase_str(PHASE_APPLYING);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    return 0;
}

