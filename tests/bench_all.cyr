# bench_all.cyr — comprehensive benchmarks for all agnosys modules
# Parity target: rust-old/benches/benchmarks.rs (18 groups, ~80 benchmarks)
#
# Build: cyrb build tests/bench_all.cyr build/bench_all
# Run:   ./build/bench_all

#define LINUX

# ================================================================
# Standard library
# ================================================================

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/tagged.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/process.cyr"
include "lib/fs.cyr"
include "lib/bench.cyr"

# ================================================================
# Agnosys modules
# ================================================================

include "src/error.cyr"
include "src/syscall.cyr"
include "src/logging.cyr"
include "src/update.cyr"
# security.cyr excluded — syscall_name_to_nr has 75 streq() calls
#   that overflow compiler tables when combined with other modules.
#   Security benchmarks are in bench_compare.cyr.
# bootloader.cyr, certpin.cyr, secureboot.cyr excluded — run_capture
#   arity conflict with process.cyr (2 args vs 5 args).

# ================================================================
# Secureboot constants + functions inlined (run_capture arity conflict)
# ================================================================

enum BenchSBState { BENCH_SB_ENABLED = 1; BENCH_SB_DISABLED = 2; }

fn bench_sb_is_enforcing(state) {
    if (state == BENCH_SB_ENABLED) { return 1; }
    return 0;
}

fn bench_sb_state_str(state) {
    if (state == BENCH_SB_ENABLED) { return "enabled"; }
    return "disabled";
}

# Bootloader benchmarks excluded — run_capture arity conflict + nested call issues
# Bootloader benchmarks are in bench_compare.cyr via security.cyr

# ================================================================
# Certpin functions inlined (full module exceeds identifier budget
# due to run_capture arity mismatch in compute_spki_pin)
# ================================================================

fn bench_certpin_validate_pin_format(pin) {
    var len = strlen(pin);
    if (len != 44) { return 0; }
    var i = 0;
    while (i < len) {
        var c = load8(pin + i);
        var valid = 0;
        if (c >= 65) { if (c <= 90) { valid = 1; } }
        if (c >= 97) { if (c <= 122) { valid = 1; } }
        if (c >= 48) { if (c <= 57) { valid = 1; } }
        if (c == 43) { valid = 1; }
        if (c == 47) { valid = 1; }
        if (c == 61) { valid = 1; }
        if (valid == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn bench_certpin_ct_streq(a, b) {
    var alen = strlen(a);
    var blen = strlen(b);
    if (alen != blen) { return 0; }
    var acc = 0;
    var i = 0;
    while (i < alen) {
        acc = acc | (load8(a + i) ^ load8(b + i));
        i = i + 1;
    }
    if (acc == 0) { return 1; }
    return 0;
}
include "src/update.cyr"
# fuse.cyr and udev.cyr excluded — identifier buffer limit

# ================================================================
# Helpers
# ================================================================

fn section(name) {
    println("");
    syscall(1, 1, "-- ", 3);
    syscall(1, 1, name, strlen(name));
    syscall(1, 1, " --", 3);
    println("");
    return 0;
}

# ================================================================
# 1. syscall group
# ================================================================

fn bench_syscall_group() {
    section("syscall");
    var iters = 1000000;

    # getpid
    var b = bench_new("getpid");
    var k = 0;
    while (k < iters) {
        bench_start(b);
        agnosys_getpid();
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # getuid
    b = bench_new("getuid");
    k = 0;
    while (k < iters) {
        bench_start(b);
        agnosys_getuid();
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # gettid
    b = bench_new("gettid");
    k = 0;
    while (k < iters) {
        bench_start(b);
        agnosys_gettid();
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # is_root
    b = bench_new("is_root");
    k = 0;
    while (k < iters) {
        bench_start(b);
        agnosys_is_root();
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # query_sysinfo
    b = bench_new("query_sysinfo");
    k = 0;
    while (k < 50000) {
        bench_start(b);
        query_sysinfo();
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    return 0;
}

# agnosys_hostname() not defined — use uname-based approach
fn bench_syscall_group_alloc() {
    section("syscall (alloc)");

    # uname hostname
    var uts[392];
    var b = bench_new("uname_hostname");
    var k = 0;
    while (k < 100000) {
        bench_start(b);
        syscall(SYS_UNAME, &uts);
        uname_hostname(&uts);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    return 0;
}

# ================================================================
# 2. error group
# ================================================================

fn bench_error_group() {
    section("error");
    var iters = 1000000;

    # syserr_pack (hot path, zero-alloc)
    var b = bench_new("syserr_pack");
    var k = 0;
    while (k < iters) {
        bench_start(b);
        syserr_pack(ERR_SYSCALL_FAILED, EPERM);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # err_from_errno — EPERM
    b = bench_new("from_errno_eperm");
    k = 0;
    while (k < iters) {
        bench_start(b);
        err_from_errno(EPERM);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # err_from_errno — EACCES
    b = bench_new("from_errno_eacces");
    k = 0;
    while (k < iters) {
        bench_start(b);
        err_from_errno(EACCES);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # err_from_errno — EAGAIN
    b = bench_new("from_errno_eagain");
    k = 0;
    while (k < iters) {
        bench_start(b);
        err_from_errno(EAGAIN);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # err_from_errno — EINVAL
    b = bench_new("from_errno_einval");
    k = 0;
    while (k < iters) {
        bench_start(b);
        err_from_errno(EINVAL);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # err_from_errno — unknown
    b = bench_new("from_errno_unknown");
    k = 0;
    while (k < iters) {
        bench_start(b);
        err_from_errno(999);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # Ok(value) creation
    b = bench_new("ok_create");
    k = 0;
    while (k < iters) {
        bench_start(b);
        Ok(42);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # wrap_syscall (success path)
    b = bench_new("wrap_syscall_ok");
    k = 0;
    while (k < iters) {
        bench_start(b);
        wrap_syscall(agnosys_getpid());
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # syserr_kind (packed)
    var packed = syserr_pack(ERR_SYSCALL_FAILED, EPERM);
    b = bench_new("syserr_kind_packed");
    k = 0;
    while (k < iters) {
        bench_start(b);
        syserr_kind(packed);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    return 0;
}

# ================================================================
# 3. certpin group
# ================================================================

fn bench_certpin_group() {
    section("certpin");
    var iters = 1000000;

    # validate_pin_format — valid
    var valid_pin = "YLh1dUR9y6Kja30RrAn7JKnbQG/uEtLMkBgFF2Fuihg=";
    var b = bench_new("validate_pin_format_valid");
    var k = 0;
    while (k < iters) {
        bench_start(b);
        bench_certpin_validate_pin_format(valid_pin);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # validate_pin_format — invalid
    b = bench_new("validate_pin_format_invalid");
    k = 0;
    while (k < iters) {
        bench_start(b);
        bench_certpin_validate_pin_format("bad");
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # ct_streq — equal
    b = bench_new("ct_streq_equal");
    k = 0;
    while (k < iters) {
        bench_start(b);
        bench_certpin_ct_streq(valid_pin, valid_pin);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    # ct_streq — not equal
    var other_pin = "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=";
    b = bench_new("ct_streq_diff");
    k = 0;
    while (k < iters) {
        bench_start(b);
        bench_certpin_ct_streq(valid_pin, other_pin);
        bench_stop(b);
        k = k + 1;
    }
    bench_report(b);

    return 0;
}

